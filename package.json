{
  "name": "workspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "artifacts/*",
    "lib/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w api-server\" \"npm run dev -w cqg-plant-inspection\"",
    "build": "npm run build --workspaces",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.18"
  }
}